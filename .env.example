# =============================================================================
# Environment Variables for Network Security Lab
# =============================================================================
# Copy this file to .env and fill in the values:  cp .env.example .env

# Tailscale Auth Key (1 key saja — untuk secure management plane)
# Generate di: https://login.tailscale.com/admin/settings/keys
# Centang "Reusable" jika diperlukan.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secret for Secure Backend
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2025
