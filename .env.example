# =============================================================================
# Environment Variables for Network Security Lab
# =============================================================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Tailscale Auth Keys
# Generate at: https://login.tailscale.com/admin/settings/keys
# Gunakan "Reusable" key agar 1 key bisa dipakai untuk semua container.
# Atau generate 3 key terpisah (satu per container Tailscale sidecar).

# Key untuk Tailscale sidecar - Vulnerable App Server
TS_AUTHKEY_VULNERABLE=tskey-auth-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Key untuk Tailscale sidecar - Secure App Server
TS_AUTHKEY_SECURE=tskey-auth-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Key untuk Tailscale sidecar - Client Victim (webtop desktop)
TS_AUTHKEY_CLIENT=tskey-auth-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Secret for Secure Backend
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2025

# Node Environment
NODE_ENV=development
